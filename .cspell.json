{
  "version": "0.2",
  "language": "en",
  "readonly": true,
  "description": "botgeSpellCheck",

  "useGitignore": true,
  "enableGlobDot": true,
  "caseSensitive": false,
  "allowCompoundWords": true,
  "validateDirectives": true,
  "ignoreRandomStrings": true,

  "dictionaries": [],
