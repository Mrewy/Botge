// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/typescript-node

{
  "name": "Botge",
  "image": "mcr.microsoft.com/devcontainers/typescript-node",

  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:": {
      "moby": false,
      "installDockerBuildx": true,
      "azureDnsAutoDetection": false,
      "installDockerComposeSwitch": true
    },
    "ghcr.io/devcontainers/features/node:": { "version": "v26.5.0", "nodeGypDependencies": false },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "postCreateCommand": {
    "global-npm-packages": "npm install -g npm-check-updates && npm install -g sort-package-json",
    "install-and-build": "npm install && npm run build",
    "directories": "mkdir -p data tmp nginx/cache/tmp && sudo chmod -R a+rwx data && sudo chmod -R a+rwx tmp && sudo chmod -R a+rx nginx/cache"
  },

  "customizations": {
    "codespaces": {
      "openFiles": ["package.json", "tsconfig.json", "src/index.ts"]
    },
    "vscode": {
      "extensions": [
        // Project
        "TypeScriptTeam.native-preview",
        "EditorConfig.EditorConfig",
        "esbenp.prettier-vscode",
        "GitHub.copilot-chat",
        "docker.docker",

        // Syntax
        "streetsidesoftware.code-spell-checker",
        "DavidAnson.vscode-markdownlint",
        "github.vscode-github-actions",
        "ahmadalli.vscode-nginx-conf",
        "dbaeumer.vscode-eslint",
        "joshbolduc.commitlint",
        "redhat.vscode-yaml",

        // Extras
        "GitHub.vscode-pull-request-github",
        "vscode-icons-team.vscode-icons",
        "aaron-bond.better-comments",
        "xlaoyu.npmrc-helper",
        "eamodio.gitlens"
      ]
    }
  }
}
