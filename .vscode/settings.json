{
  "workbench.startupEditor": "none",
  "workbench.iconTheme": "vscode-icons",

  "vsicons.associations.files": [
    { "icon": "cspell", "extensions": ["cspell.config.ts"], "filename": true, "format": "svg" }
  ],

  "workbench.list.smoothScrolling": true,

  "terminal.integrated.shellIntegration.enabled": true,

  "terminal.integrated.suggest.enabled": true,
  "terminal.integrated.suggest.showStatusBar": true,
  "terminal.integrated.suggest.insertTrailingSpace": true,
  "terminal.integrated.suggest.quickSuggestions": {
    "commands": "on",
    "arguments": "on",
    "unknown": "off"
  },

  "terminal.integrated.tabs.title": "botge${separator}${process}",
  "terminal.integrated.tabs.showActions": "singleTerminalOrNarrow",
  "terminal.integrated.tabs.showActiveTerminal": "always",

  "terminal.integrated.enablePersistentSessions": false,
  "terminal.integrated.persistentSessionReviveProcess": "never",

  "terminal.integrated.gpuAcceleration": "auto",
  "terminal.integrated.enableImages": false,

  "terminal.integrated.smoothScrolling": true,

  "github.copilot.enable": {
    "*": false
  },
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,
  "github.copilot.nextEditSuggestions.enabled": false,
  "github.copilot.chat.codesearch.enabled": true,
  "github.copilot.chat.languageContext.fix.typescript.enabled": true,
  "github.copilot.chat.languageContext.inline.typescript.enabled": true,
  "github.copilot.chat.languageContext.typescript.enabled": true,
  "github.copilot.chat.languageContext.typescript.includeDocumentation": true,

  "json.schemaDownload.trustedDomains": {
    "https://schemastore.azurewebsites.net/": true,
    "https://raw.githubusercontent.com/microsoft/vscode/": true,
    "https://raw.githubusercontent.com/devcontainers/spec/": true,
    "https://www.schemastore.org/": true,
    "https://json.schemastore.org/": true,
    "https://json-schema.org/": true,
    "https://developer.microsoft.com/json-schemas/": true,
    "https://nodejs.org/docs/v26.2.0/node-config-schema.json": true
  },

  "telemetry.feedback.enabled": false,
  "files.autoSave": "onFocusChange",

  "git.alwaysSignOff": false,
  "git.autofetch": true,
  "git.enableCommitSigning": true,
  "diffEditor.ignoreTrimWhitespace": false,

  "npm.packageManager": "npm",
  "npm.scriptRunner": "npm",

  "js/ts.experimental.useTsgo": true,

  "js/ts.implicitProjectConfig.module": "NodeNext",
  "js/ts.implicitProjectConfig.target": "ESNext",

  "js/ts.updateImportsOnFileMove.enabled": "prompt",

  "js/ts.tsserver.checkNpmIsInstalled": true,
  "js/ts.preferences.importModuleSpecifierEnding": "js",
  "js/ts.preferences.preferTypeOnlyAutoImports": true,
  "js/ts.preferences.quoteStyle": "single",
  "js/ts.format.semicolons": "insert",

  "docker.lsp.experimental.vulnerabilityScanning": true,
  "docker.lsp.experimental.scout.notPinnedDigest": false,
  "docker.lsp.experimental.scout.recommendedTag": true,
  "docker.lsp.telemetry": "error",

  "eslint.runtime": "node",
  "eslint.options": {
    "flags": ["unstable_native_nodejs_ts_config"]
  },

  "prettier.requireConfig": true,
  "prettier.configPath": "prettier.config.ts",
  "prettier.ignorePath": ".prettierignore",

  "redhat.telemetry.enabled": false,
  "yaml.format.printWidth": 120,
  "yaml.format.singleQuote": true,

  "editor.experimentalGpuAcceleration": "on",
  "editor.smoothScrolling": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true
}
