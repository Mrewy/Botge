{
  "name": "botge",
  "version": "3.0.1",
  "private": true,
  "description": "Search emotes, clips, use zero-width emotes and other such commands.",
  "keywords": [
    "bot",
    "discord",
    "discord-bot",
    "emotes"
  ],
  "bugs": {
    "url": "https://github.com/Mrewy/Botge/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mrewy/Botge.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Mrewy"
  },
  "license": "MIT",
  "author": "Mrewy",
  "contributors": [
    "gentlebob",
    "widepogcrazy",
    "TimotronPrime",
    "ravenuy"
  ],
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --build src",
    "build:clean": "tsc --build --clean src",
    "build:production": "tsc --project src/tsconfig.production.json",
    "cspell": "cspell . --verbose",
    "eslint": "eslint \"**/*.ts\" --flag unstable_native_nodejs_ts_config --concurrency=auto",
    "markdownlint": "markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
    "prepare": "node .husky/install.ts",
    "prettier": "prettier . --write",
    "start": "docker image prune --force && docker compose up --build",
    "stop": "docker compose stop",
    "test": "vitest tests"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "@twemoji/api": "^17.0.3",
    "chromadb": "^3.5.0",
    "deepl-node": "^1.27.0",
    "discord.js": "^14.27.0",
    "fs-extra": "^11.3.6",
    "helpful-decorators": "^2.1.0",
    "meilisearch": "^0.60.0",
    "node-fetch": "^3.3.2",
    "node-schedule": "^2.1.1",
    "openai": "^6.48.0",
    "timezones-list": "^3.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@commitlint/format": "^21.2.0",
    "@commitlint/types": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@microsoft/tsdoc-config": "^0.18.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^26.1.1",
    "@types/node-schedule": "^2.1.8",
    "@typescript/native": "npm:typescript@^7.1.0-dev.20260723.1",
    "cspell": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-plugin-tsdoc": "^0.5.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.2.0",
    "markdownlint-cli2": "^0.23.1",
    "prettier": "^3.9.6",
    "prettier-plugin-sh": "^0.19.0",
    "ts-essentials": "^10.2.1",
    "typescript": "npm:@typescript/typescript6@^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": "v26.5.0",
    "npm": ">=11.17.0"
  },
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "allowScripts": {
    "fsevents": true
  }
}
