{
  "name": "botge",
  "version": "3.0.1",
  "private": true,
  "description": "Search emotes, clips, use zero-width emotes and other such commands.",
  "keywords": [
    "bot",
    "discord",
    "discord-bot",
    "emotes"
  ],
  "bugs": {
    "url": "https://github.com/Mrewy/Botge/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mrewy/Botge.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Mrewy"
  },
  "license": "MIT",
  "author": "Mrewy",
  "contributors": [
    "gentlebob",
    "widepogcrazy",
    "TimotronPrime",
    "ravenuy"
  ],
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsgo --build src",
    "build:clean": "tsgo --build --clean src",
    "build:production": "tsgo --project src/tsconfig.production.json",
    "commitlint": "commitlint --edit",
    "cspell": "cspell . --verbose",
    "cspell:commit-msg": "cspell --no-summary --no-progress --language-id commit-msg",
    "cspell:pre-commit": "git diff --cached --name-only | cspell --no-summary --no-progress --no-must-find-files --file-list stdin",
    "eslint": "eslint . --flag unstable_native_nodejs_ts_config --concurrency=auto",
    "markdownlint": "markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
    "prepare": "node .husky/install.ts",
    "prettier": "prettier . --write",
    "start": "docker image prune --force && docker compose up --build",
    "stop": "docker compose stop",
    "test": "vitest tests",
    "test:pre-commit": "vitest tests --no-color"
  },
  "dependencies": {
    "@discordjs/voice": "0.19.2",
    "@twemoji/api": "17.0.3",
    "chromadb": "3.4.3",
    "deepl-node": "1.27.0",
    "discord.js": "14.26.4",
    "fs-extra": "11.3.5",
    "helpful-decorators": "2.1.0",
    "meilisearch": "0.58.0",
    "node-fetch": "3.3.2",
    "node-schedule": "2.1.1",
    "openai": "6.45.0",
    "timezones-list": "3.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-conventional": "21.1.0",
    "@commitlint/format": "21.1.0",
    "@commitlint/types": "21.1.0",
    "@eslint/js": "10.0.1",
    "@microsoft/tsdoc-config": "0.18.1",
    "@types/fs-extra": "11.0.4",
    "@types/node": "26.0.1",
    "@types/node-schedule": "2.1.8",
    "@typescript/native-preview": "7.0.0-dev.20260624.1",
    "cspell": "10.0.1",
    "eslint": "10.5.0",
    "eslint-plugin-tsdoc": "0.5.2",
    "husky": "9.1.7",
    "markdownlint-cli2": "0.22.1",
    "prettier": "3.8.5",
    "prettier-plugin-sh": "0.18.1",
    "ts-essentials": "10.2.1",
    "typescript-eslint": "8.62.0",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": "v26.4.0",
    "npm": ">=11.17.0"
  },
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "allowScripts": {
    "fsevents": true
  }
}
